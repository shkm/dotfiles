#!/usr/bin/env bash
#
# Detect OS appearance and output theme variables.
# Exits 0 for dark, 1 for light.
#
# Usage:
#   eval "$(theme-env)"       # POSIX sh
#   eval (theme-env)          # fish (via fenv in .profile)

dark=1

case "$(uname)" in
  Darwin)
    defaults read -g AppleInterfaceStyle &>/dev/null || dark=0
    ;;
  *)
    scheme=$(gsettings get org.gnome.desktop.interface color-scheme 2>/dev/null)
    [[ "$scheme" == *dark* ]] || dark=0
    ;;
esac

if [ "$dark" -eq 1 ]; then
  theme=catppuccin-mocha
else
  theme=catppuccin-latte
fi

echo "export DARK_MODE=$dark"
echo "export DARK_MODE_THEME=catppuccin-mocha"
echo "export LIGHT_MODE_THEME=catppuccin-latte"
echo "export THEME=$theme"

exit $(( 1 - dark ))
