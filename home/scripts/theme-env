#!/usr/bin/env bash
#
# Detect OS appearance and output theme variables.
# Exits 0 for dark, 1 for light.
#
# Usage:
#   eval "$(theme-env)"       # POSIX sh
#   eval (theme-env)          # fish (via fenv in .profile)

dark=1

case "$(uname)" in
  Darwin)
    [[ "$(dark-mode status)" == "on" ]] || dark=0
    ;;
  *)
    scheme=$(gsettings get org.gnome.desktop.interface color-scheme 2>/dev/null)
    [[ "$scheme" == *dark* ]] || dark=0
    ;;
esac

dark_theme=catppuccin-mocha
light_theme=catppuccin-latte

if [ "$dark" -eq 1 ]; then
  theme=$dark_theme
  bat_theme="Catppuccin Mocha"
else
  theme=$light_theme
  bat_theme="Catppuccin Latte"
fi

echo "export DARK_MODE=$dark"
echo "export DARK_MODE_THEME=$dark_theme"
echo "export LIGHT_MODE_THEME=$light_theme"
echo "export THEME=$theme"
echo "export BAT_THEME=\"$bat_theme\""

exit $(( 1 - dark ))
