#!/bin/bash
set -euo pipefail

DOTFILES_DIR="$(cd "$(dirname "$0")/.." && pwd)"
DOTFILES_HOME="$DOTFILES_DIR/home"

# Link src -> dest. Idempotent; prompts on non-symlink conflicts.
link() {
  local src="$1" dest="$2"

  if [ -L "$dest" ]; then
    local current
    current=$(readlink "$dest")
    if [ "$current" = "$src" ]; then
      return
    fi
    echo "  relink: $dest (was $current)"
    ln -sfn "$src" "$dest"
  elif [ -e "$dest" ]; then
    echo "  conflict: $dest (exists and is not a symlink)"
    read -rp "  overwrite? [y/N] " answer </dev/tty
    if [[ "$answer" =~ ^[Yy]$ ]]; then
      rm -rf "$dest"
      ln -sfn "$src" "$dest"
    fi
  else
    echo "  link: $dest"
    ln -sfn "$src" "$dest"
  fi
}

# Stow-style tree folding:
#   - if dest already exists as a real directory and src is a directory,
#     recurse into children (shared dir — don't claim the whole thing)
#   - otherwise link src to dest as a single symlink
fold() {
  local src="$1" dest="$2"

  if [ -d "$src" ] && [ ! -L "$src" ] && [ -d "$dest" ] && [ ! -L "$dest" ]; then
    while IFS= read -r child; do
      local name
      name=$(basename "$child")
      [ "$name" = ".DS_Store" ] && continue
      fold "$child" "$dest/$name"
    done < <(find "$src" -maxdepth 1 -mindepth 1)
  else
    link "$src" "$dest"
  fi
}

echo "Linking dotfiles..."

while IFS= read -r child; do
  name=$(basename "$child")
  [ "$name" = ".DS_Store" ] && continue
  fold "$child" "$HOME/$name"
done < <(find "$DOTFILES_HOME" -maxdepth 1 -mindepth 1)
