{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(*)",
      "mcp__github__*",
      "mcp__plugin_context7_context7__*",
      "mcp__plugin_repomix-mcp_repomix__*",
      "WebSearch",
      "WebFetch",
      "Read(~/.ssh/*.pub)"
    ],
    "deny": [
      "Read(~/.ssh/**)",
      "Read(~/.gnupg/**)",
      "Read(~/.aws/**)",
      "Read(~/.config/gcloud/**)",
      "Read(~/.kube/**)",
      "Read(~/.docker/**)",
      "Read(~/.config/gh/**)",
      "Read(~/.netrc)",
      "Read(~/.git-credentials)",
      "Read(~/.cargo/credentials*)",
      "Read(~/.pypirc)",
      "Read(.kamal/secrets)",
      "Read(**/.env)",
      "Read(**/.env.*)",
      "Read(~/.bundle/config)"
    ],
    "defaultMode": "acceptEdits",
    "additionalDirectories": [
      "/Users/jamie/.workspaces",
      "/Users/jamie/"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Read|Write|Edit|Bash",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/guard-files.sh",
            "timeout": 5
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/scripts/claude-notify"
          }
        ]
      }
    ],
    "Notification": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/scripts/claude-notify"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "input=$(cat); model=$(echo \"$input\" | jq -r '.model.display_name'); worktree=$(echo \"$input\" | jq -r '.workspace.current_dir'); branch=$(cd \"$worktree\" && git rev-parse --abbrev-ref HEAD 2>/dev/null || echo \"no-git\"); usage=$(echo \"$input\" | jq '.context_window.current_usage'); if [ \"$usage\" != \"null\" ]; then context_tokens=$(echo \"$usage\" | jq '.input_tokens + .cache_creation_input_tokens + .cache_read_input_tokens'); else context_tokens=0; fi; if [ \"$context_tokens\" -ge 1000 ]; then tokens_short=\"$((context_tokens / 1000))k\"; else tokens_short=\"$context_tokens\"; fi; printf '\\033[36m%s\\033[0m · \\033[35m%s\\033[0m · \\033[33m%s\\033[0m · \\033[34m%s\\033[0m' \"$model\" \"$(basename \"$worktree\")\" \"$branch\" \"$tokens_short\""
  },
  "enabledPlugins": {
    "frontend-design@claude-plugins-official": true,
    "commit-commands@claude-plugins-official": true,
    "context7@claude-plugins-official": true,
    "feature-dev@claude-plugins-official": true,
    "security-guidance@claude-plugins-official": true,
    "repomix-mcp@repomix": true,
    "swift-lsp@claude-plugins-official": true,
    "rust-analyzer-lsp@claude-plugins-official": true,
    "lua-lsp@claude-plugins-official": true
  },
  "sandbox": {
    "enabled": false
  },
  "spinnerVerbs": {
    "mode": "replace",
    "verbs": [
      " "
    ]
  },
  "prefersReducedMotion": true,
  "terminal": {
    "vimMode": false
  },
  "includePrerelease": false,
  "model": "opus[1m]"
}
